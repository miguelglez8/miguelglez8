<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.3.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_3_0.dtd">

<service-builder dependency-injector="ds" package-path="com.canal.etico.v2.liferay.portlet.canal.manager">
	<namespace>canal_plus</namespace>

	<entity local-service="true" name="Comunicado"  cache-enabled="false">
		<!-- PK fields -->
		<column name="comunicadoId" primary="true" type="long" />
		<!-- Other fields -->
		<column name="codigo" type="String" />
		<column name="cif" type="String" />
		<column name="compId" type="long" />
		<column name="vinculacion" type="String" />
		<column name="email" type="String" />
		<column name="nombre" type="String" />
		<column name="apellidos" type="String" />
		<column name="nif" type="String" />
		<column name="telefono" type="String" />

		<column name="direccionPostal" type="String" />
		<column name="otros" type="String" />
		<column name="gestorId"  type="String" />
		<column name="gestorLabel" type="String" />

		<column name="idGrupoEmpresa"  type="long" />
		<column name="nombreEmpresa"  type="String" />
		<column name="anonimo" type="boolean" />
		<column name="tipo" type="long" />
		<column name="categoria" type="long" />
		<column name="categoriaDesc" type="String" />
		<column name="asunto" type="String" />
		<column name="descripcion" type="String" />
		<column name="estado" type="long" />
		<column name="motivoId" type="long" />
		<column name="observaciones" type="String"/>
		<column name="prorrogado" type="boolean" />
		<column name="notificacion" type="String"/>
		<!-- Audit fields -->
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />
		<column name="endDate" type="Date" />

		<column name="caducidadDate" type="Date" />
		<column name="adjuntosId" type="String" />

		<!-- Order -->
		<order by="desc">
			<order-column name="createDate" />
		</order>

		<!-- Finder methods -->
		<finder name="CompId" return-type="Collection">
			<finder-column name="compId" />
		</finder>
		<finder name="Email" return-type="Collection">
			<finder-column name="email" />
		</finder>
		<finder name="Codigo" return-type="Collection">
			<finder-column name="codigo" />
		</finder>
		<finder name="Estado" return-type="Collection">
			<finder-column name="estado" />
		</finder>
		<finder name="ComunicadoId" return-type="Collection">
			<finder-column name="comunicadoId" />
		</finder>
	</entity>

	<entity local-service="true" name="Categoria"  cache-enabled="false">
		<column name="categoriaId" primary="true" type="long" />

		<column name="compId"  type="long" />
		<column name="nombre" type="String"/>
		<!-- NUEVAS -->
		<column name="nombre_cat" type="String"/>
		<column name="nombre_eng" type="String"/>
		<!-- END NUEVAS -->
		<column name="tipo" type="String"/>
		<column name="codigo" type="String"/>
		<column name="activo" type="boolean" />

		<column name="createBy" type="String" />
		<column name="createDate" type="Date" />
		<column name="deleteData" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- <finder name="Nombre" return-type="Collection">
			<finder-column name="nombre" />
		</finder> -->
		<finder name="CompId" return-type="Collection">
			<finder-column name="compId" />
		</finder>
	</entity>

	<entity local-service="true" name="Accion" cache-enabled="false">
		<!-- PK fields -->
		<column name="accionId" primary="true" type="long" />
		<!-- Other fields -->
		<column name="compId" type="long" />
		<column name="nombre" type="String" localized="true"/>
		<!-- NUEVAS -->
		<column name="nombre_cat" type="String"/>
		<column name="nombre_eng" type="String"/>
		<!-- END NUEVAS -->
		<column name="estado" type="long" />
		<column name="activo" type="boolean" />
		<!-- Audit fields -->
		<column name="createBy" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />
		<column name="endDate" type="Date" />
		<!-- Order -->
		<order by="asc">
			<order-column name="nombre" />
		</order>

		<!-- Finder methods -->
		<!-- <finder name="Nombre" return-type="Collection">
			<finder-column name="nombre" />
		</finder> -->
		<finder name="CompId" return-type="Collection">
			<finder-column name="compId" />
		</finder>
	</entity>

	<entity local-service="true" name="Comp" cache-enabled="false">

		<!-- PK fields -->
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="observations" type="String" localized="true" />
		<column name="active" type="boolean" />
		<column name="urlId" type="String" />
		<column name="startDate" type="Date" />
		<column name="deleteDate" type="Date" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />
		<!-- adjuntos ids -->
		<column name="politicaFileId" type="String" />
		<column name="procedimientoFileId" type="String" />


		<!-- Finder methods -->
		<!-- <finder name="SuiteCompId" return-type="Comp" unique="true">
			<finder-column name="suiteCompId" />
		</finder> -->
		<finder name="CompId" return-type="Collection">
			<finder-column name="compId" />
		</finder>
		<finder name="urlId" return-type="Collection">
			<finder-column name="urlId" />
		</finder>


	</entity >

	<entity local-service="true" name="GrupoEmpresa" cache-enabled="false">

		<!-- PK fields -->
		<column name="grupoEmpresasId" primary="true" type="long" />
		<!-- Other fields -->
		<column name="compId" type="long" />
		<column name="entidad" type="String" localized="true" />
		<column name="cif" type="String" localized="true" />
		<column name="numTrabajadores" type="long" />

		<!-- Finder methods -->
		<finder name="CompId" return-type="Collection">
			<finder-column name="compId" />
		</finder>


	</entity >

	<entity local-service="true" name="ComunicadoAccion" cache-enabled="false">

		<!-- PK fields -->
		<column name="comunicadoAccionId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="comunicadoId" type="long" />
		<column name="accionId" type="long" />
		<column name="userId" type="long" />
		<column name="observaciones" type="String"/>
		<column name="idEstado" type="long" />
		<column name="notificado" type="boolean" />
		<!-- Audit fields -->
		<column name="aplicateDate" type="Date" />
		<column name="createBy" type="String"/>
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- adjuntos ids-->
		<column name="fileId" type="String"/>

		<!-- Order -->
		<order by="asc">
			<order-column name="comunicadoId" />
		</order>

		<!-- Finder methods -->
		<finder name="ComunicadoId" return-type="Collection">
			<finder-column name="comunicadoId" />
		</finder>
		<finder name="Comunicado_accion" return-type="Collection">
			<finder-column name="comunicadoAccionId" />
			<finder-column name="accionId" />
		</finder>

	</entity>
	<entity local-service="true" name="ComunicadoAdicional" cache-enabled="false">
		<column name="comunicadoAdicionalId" primary="true" type="long" />
		<column name="codigoComunicado" type="String" />
		<column name="asunto" type="String" />
		<column name="descripcion" type="String" />
		<column name="fileId" type="String"/>
		<column name="createDate" type="Date" />
		<column name="idComunicado" type="long" />
		<!-- Finder methods -->
		<finder name="codigoComunicado" return-type="Collection">
			<finder-column name="codigoComunicado" />
		</finder>
	</entity>
</service-builder>