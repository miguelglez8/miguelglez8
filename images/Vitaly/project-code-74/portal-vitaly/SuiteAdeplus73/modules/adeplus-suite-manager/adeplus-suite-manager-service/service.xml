<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.2.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_2_0.dtd">

<service-builder dependency-injector="ds" package-path="com.adeplus.liferay.portlet.suite.manager">
	<namespace>adeplus</namespace>



	<entity local-service="true" name="Comp">
		<!-- PK fields -->
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="cif" type="String" />
		<column name="name" type="String" />
		<column name="description" type="String" localized="true"/>
		<column name="observations" type="String" localized="true"/>
		<column name="agreement" type="String" localized="true"/>
		<column name="idCrm" type="String" />
		<column name="idContrato" type="String" />
		<column name="idEstado" type="String" />
		<column name="logo" type="long" />
		<column name="startDate" type="Date" />
		<column name="deleteDate" type="Date" />

		<!-- Audit fields -->
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Order -->
		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder methods -->
		<finder name="cif" return-type="Comp" unique="true">
			<finder-column name="cif" />
		</finder>

		<finder name="name" return-type="Collection">
			<finder-column name="name" />
		</finder>

		<finder name="nameAndCif" return-type="Comp">
			<finder-column name="name" />
			<finder-column name="cif" />
		</finder>

	</entity>

	<entity local-service="true" name="Application">

		<!-- PK fields -->
		<column name="applicationId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="name" type="String" />
		<column name="description" type="String" localized="true" />
		<column name="url" type="String" />
		<column name="configuration" type="String" />
		<column name="roles" type="String" />
		<column name="alias" type="String" />
		<column name="keycloak_client" type="String" />
		<column name="keycloak_secret" type="String" />
		<column name="logo" type="long" />
		<column name="order" type="Integer" />

		<column name="limitAdmins" type="boolean" />
		<column name="limitUsers" type="boolean" />
		<column name="limitNumAdmins" type="long" />
		<column name="limitNumUsers" type="long" />

		<!-- Audit fields -->
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Order -->
		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder methods -->
		<finder name="name" return-type="Collection">
			<finder-column name="name" />
		</finder>
		<finder name="alias" return-type="Collection">
			<finder-column name="alias" />
		</finder>

	</entity>

	<entity local-service="true" name="ApplicationLicense">

		<!-- PK fields -->
		<column name="licenseId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="applicationId" type="long" />
