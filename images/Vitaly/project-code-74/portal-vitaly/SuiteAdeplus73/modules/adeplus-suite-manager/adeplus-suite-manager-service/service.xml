			<order-column name="applicationId" />
		</order>

		<!-- Finder methods -->
		<finder name="ApplicationId" return-type="Collection">
			<finder-column name="applicationId" />
		</finder>
		<finder name="LicenseId" return-type="ApplicationLicense" unique="true">
			<finder-column name="licenseId" />
		</finder>
		<finder name="AppLicense" return-type="ApplicationLicense" unique="true">
			<finder-column name="applicationId" />
			<finder-column name="licenseId" />
		</finder>

	</entity>

