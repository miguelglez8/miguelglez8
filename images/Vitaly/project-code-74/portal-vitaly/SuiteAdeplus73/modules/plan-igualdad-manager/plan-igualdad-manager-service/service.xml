<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.3.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_3_0.dtd">

<service-builder dependency-injector="ds" package-path="com.plan.igualdad.liferay.portlet.manager">
	<namespace>planigualdad</namespace>

	<entity local-service="true" name="Version">

		<!-- PK fields -->
		<column name="versionId" primary="true" type="long" />
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="nombre" type="String" />
		<column name="inicioPeriodoDatos" type="Date" />
		<column name="finPeriodoDatos" type="Date" />
		<column name="inicioPeriodoPlan" type="Date" />
		<column name="finPeriodoPlan" type="Date" />
		<column name="baja" type="Date" />

		<!-- Audit fields -->
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Order -->
		<order by="desc">
			<order-column name="versionId" />
			<order-column name="compId" />
		</order>

		<!-- Finder methods -->
		<finder name="Version" return-type="Version" unique="true">
			<finder-column name="versionId" />
			<finder-column name="compId" />
		</finder>
		<finder name="Comp" return-type="Collection">
			<finder-column name="compId" />
		</finder>

	</entity>

	<entity local-service="true" name="Hito">

		<!-- PK fields -->
		<column name="hitoId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="nombre" type="String" />
		<column name="peso" type="String" />

	</entity>

	<entity local-service="true" name="FechaHito">

		<!-- PK fields -->
		<column name="hitoId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="fecha" type="Date" />

		<!-- Finder methods -->
		<finder name="FechaHito" return-type="Collection">
			<finder-column name="versionId" />
			<finder-column name="compId" />
		</finder>

	</entity>

	<entity local-service="true" name="Area">

		<!-- PK fields -->
		<column name="areaId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="nombre" type="String" />
		<column name="baja" type="Date" />

		<!-- Finder methods -->
		<finder name="Area" return-type="Collection">
			<finder-column name="versionId" />
			<finder-column name="compId" />
		</finder>

	</entity>

	<entity local-service="true" name="PuestoTrabajo">

		<!-- PK fields -->
		<column name="puestoId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="nombre" type="String" />
		<column name="areaId" type="long" />
		<column name="responsabilidad" type="long" />
		<column name="nHombres" type="long" />
		<column name="nMujeres" type="long" />
		<column name="baja" type="Date" />

		<!-- Finder methods -->
		<finder name="PuestoTrabajo" return-type="Collection">
			<finder-column name="versionId" />
			<finder-column name="compId" />
		</finder>
		<finder name="PuestoArea" return-type="Collection">
			<finder-column name="versionId" />
			<finder-column name="compId" />
			<finder-column name="areaId" />
		</finder>
		<finder name="PuestoResponsabilidad" return-type="Collection">
			<finder-column name="versionId" />
			<finder-column name="compId" />
			<finder-column name="responsabilidad" />
		</finder>

	</entity>

	<entity local-service="true" name="Organizacion">

		<!-- PK fields -->
		<column name="organizacionId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="compId" primary="true" type="long" />

		<!-- Other fields -->
