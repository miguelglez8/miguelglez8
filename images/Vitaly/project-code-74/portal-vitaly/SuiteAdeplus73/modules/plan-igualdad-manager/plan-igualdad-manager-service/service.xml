		</finder>
	</entity>
	
	<entity local-service="true" name="Estado">
		<!-- PK fields -->
		<column name="estadoId" primary="true" type="long" />
		
		<!-- Other fields -->
		<column name="nombre" type="String" />
		<column name="activa" type="Boolean"/>
		<column name="gestionParametrizaciones" type="Boolean"/>
		
		<!-- Finder methods -->
		<finder name="Activa" return-type="Collection">
			<finder-column name="activa" />
		</finder>
	</entity>
</service-builder>