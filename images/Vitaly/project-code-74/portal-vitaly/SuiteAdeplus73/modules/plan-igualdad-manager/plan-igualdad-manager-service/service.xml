		</finder>
		
		<finder name="EstadisticaSeccion" return-type="Estadistica">
			<finder-column name="compId" />
			<finder-column name="versionId" />
			<finder-column name="seccionId" />
		</finder>

	</entity>
	
	<entity local-service="true" name="ImagenCanvasEst">
		<!-- PK fields -->
		<column name="compId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="seccionId" primary="true" type="long" />
		<column name="imgCanvasId" primary="true" type="String" />
		<column name="parteImg" primary="true" type="long" />
		
		<!-- Other fields -->
		<column name="canvasImage" type="String" />
		
		<!-- Finder methods -->
		<finder name="Secciones" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
		</finder>
		
		<finder name="ImagenCanvasSeccion" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
			<finder-column name="seccionId" />
			<finder-column name="imgCanvasId" />
		</finder>
	</entity>
	
	<entity local-service="true" name="ParametricasFDD">
		
		<!-- PK fields -->
		<column name="compId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="idParametrica" primary="true" type="String" />
		
		<!-- Other fields -->
		<column name="tipo" type="String" />
		<column name="materia" type="Integer" />
		<column name="contenido" type="String" />
		<column name="seccionId" type="long" />
		
		<!-- Finder methods -->
		<finder name="Materia" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
			<finder-column name="tipo" />
			<finder-column name="materia" />
		</finder>
		
		<finder name="Tipo" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
			<finder-column name="tipo" />
		</finder>
		
		<finder name="CompIdAndVersion" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
		</finder>
		
		<finder name="Parametrica" return-type="ParametricasFDD">
			<finder-column name="compId" />
			<finder-column name="versionId" />
			<finder-column name="idParametrica" />
		</finder>
	</entity>
	
	<entity local-service="true" name="Informes">
		<!-- PK fields -->
		<column name="informeId" primary="true" type="long" />
		
		<!-- Other fields -->
		<column name="compId" type="long" />
		<column name="userId" type="long" />
		<column name="versionId" type="long" />
		<column name="tipoInforme" type="String" />
		<column name="versionInforme" type="Integer"/>
		<column name="parametrosInforme" type="String" />
		<column name="beansInforme" type="String" />
		<column name="formato" type="String" />
		
		<!-- Audit fields -->
		<column name="createDate" type="Date" />
		
		<!-- Finder methods -->
		<finder name="InformeVersions" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
			<finder-column name="tipoInforme" />
		</finder>
		
		<finder name="Comp" return-type="Collection">
			<finder-column name="compId" />
		</finder>
	</entity>
	
	<entity local-service="true" name="Evaluacion">

		<!-- PK fields -->
		<column name="evaluacionId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="compId" type="long" />
		<column name="versionId" type="long" />
		<column name="userId" type="long" />
		<column name="datosGenerales" type="String" />
		<column name="informacionResultados" type="String" />
		<column name="informacionImplantacion" type="String" />
		<column name="informacionImpacto" type="String" />
		<column name="conclusion" type="String" />
		<column name="observaciones" type="String" />
		<column name="versionEvaluacion" type="Integer"/>
		
		<!-- Audit fields -->
		<column name="createDate" type="Date" />

		<!-- Finder methods -->
		<finder name="Evaluaciones" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
		</finder>
		
		<finder name="Comp" return-type="Collection">
			<finder-column name="compId" />
		</finder>
	</entity>
	
	<entity local-service="true" name="Medida">
		<!-- PK fields -->
		<column name="medidaId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="compId" type="long" />
