		<column name="paginaWeb" type="String" />
		<column name="domicilioSocial" type="String" />
		<column name="facturacionAnual" type="String" />
		<column name="formaJuridica" type="String" />
		<column name="nombreResponsableEntidad" type="String" />
		<column name="telefonoResponsableEntidad" type="String" />
		<column name="cargoResponsableEntidad" type="String" />
		<column name="emailResponsableEntidad" type="String" />
		<column name="nombreResponsableIgualdad" type="String" />
		<column name="telefonoResponsableIgualdad" type="String" />
		<column name="cargoResponsableIgualdad" type="String" />
		<column name="emailResponsableIgualdad" type="String" />
		<column name="cnaes" type="String" />
		<column name="nCentros" type="long" />
		<column name="descripcionActividad" type="String" />
		<column name="convenio" type="String" />
		<column name="ambito" type="String" />
		<column name="comentarioAmbito" type="String" />
		<column name="nHombresPlantilla" type="long" />
		<column name="nMujeresPlantilla" type="long" />
		<column name="representacionLegal" type="String" />
		<column name="nRepresentacionLegalHombres" type="long" />
		<column name="nRepresentacionLegalMujeres" type="long" />
		<column name="representaTotalidad" type="String" />
		<column name="nNoRepresentados" type="long" />
		<column name="comentarioRepresentacion" type="String" />
		<column name="departamentoPersonal" type="String" />
		<column name="sindicatos" type="String" />
		<column name="reprComisionOrganizacion" type="String" />
		<column name="reprComisionSocial" type="String" />
		<column name="reprPlanOrganizacion" type="String" />
		<column name="reprPlanSociales" type="String" />

		<!-- Finder methods -->
		<finder name="Organizacion" return-type="Organizacion" unique="true">
			<finder-column name="versionId" />
			<finder-column name="compId" />
		</finder>

	</entity>

	<entity local-service="true" name="Pregunta">

		<!-- PK fields -->
		<column name="preguntaId" primary="true" type="long" />
		<column name="seccionId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="tipo" type="String" />
		<column name="pregunta" type="String" />

		<!-- Finder methods -->
		<finder name="Seccion" return-type="Collection">
			<finder-column name="seccionId" />
		</finder>

	</entity>

	<entity local-service="true" name="Respuesta">

		<!-- PK fields -->
		<column name="compId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="seccionId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="respuestas" type="String" />
		<column name="estado" type="long" />

		<!-- Finder methods -->
		<finder name="Secciones" return-type="Collection">
			<finder-column name="compId" />
			<finder-column name="versionId" />
		</finder>
		
		<finder name="RespuestasSeccion" return-type="Respuesta" unique="true">
			<finder-column name="versionId" />
			<finder-column name="compId" />
			<finder-column name="seccionId" />
		</finder>

	</entity>

	<entity local-service="true" name="Estadistica">

		<!-- PK fields -->
		<column name="compId" primary="true" type="long" />
		<column name="versionId" primary="true" type="long" />
		<column name="seccionId" primary="true" type="long" />

		<!-- Other fields -->
		<column name="estadistica" type="String" />

		<!-- Finder methods -->
		<finder name="Secciones" return-type="Collection">
