				</textElement>
				<text><![CDATA[INDICADORES PROPUESTOS:]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="580" width="475" height="60" forecolor="#1F497D" uuid="74d40aed-83c9-40c0-a2d8-2cd1470242ba">
