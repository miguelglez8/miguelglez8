								<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#FFFFFF"/>
								<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#FFFFFF"/>
							</box>
							<textElement textAlignment="Center" verticalAlignment="Middle">
								<font fontName="Corbel" isBold="true" isItalic="false" isUnderline="false"/>
							</textElement>
							<text><![CDATA[FICHA DE MEDIDA]]></text>
						</staticText>
						<frame>
							<reportElement positionType="Float" mode="Transparent" x="0" y="210" width="486" height="40" backcolor="#FFFFFF" uuid="b64ddb16-eab4-4e53-b21b-3529c3740599">
								<property name="com.jaspersoft.studio.unit.y" value="px"/>
