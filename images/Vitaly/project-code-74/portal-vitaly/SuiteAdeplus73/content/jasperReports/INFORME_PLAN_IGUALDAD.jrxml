					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[e) Persona/s responsable/s de la indicada implementación y seguimiento]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="180" width="475" height="40" forecolor="#1F497D" uuid="981c108f-5e9a-488c-a1a6-da1fbd501a9a">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[Será la Comisión de Seguimiento, la encargada del análisis y evaluación del cumplimiento, implantación y desarrollo de este Plan de Igualdad.]]></text>
			</staticText>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" mode="Transparent" x="30" y="220" width="475" height="60" forecolor="#1F497D" uuid="3b59914b-5a7a-44f6-bd10-93d6562ccd06">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Dicha Comisión de seguimiento se constituye para interpretar el contenido del Plan y evaluar el grado de cumplimiento del mismo, de los objetivos marcados y de las acciones programadas. La Comisión de Seguimiento y Evaluación tendrá la responsabilidad de realizar el seguimiento y la evaluación del Plan de Igualdad de " + $P{razonSocial} + "."]]></textFieldExpression>
			</textField>
			<staticText>
