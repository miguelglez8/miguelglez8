			<staticText>
				<reportElement mode="Opaque" x="150" y="460" width="170" height="100" forecolor="#1F497D" uuid="05a7c369-bdae-4072-a655-2da4137bc99b"/>
				<box leftPadding="10" rightPadding="10">
