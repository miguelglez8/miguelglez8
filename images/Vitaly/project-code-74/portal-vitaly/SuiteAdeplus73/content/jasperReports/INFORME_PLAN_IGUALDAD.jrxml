					<font fontName="Corbel" size="10" isBold="true"/>
				</textElement>
				<text><![CDATA[VALORACIÓN A REALIZAR]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="150" y="430" width="170" height="30" forecolor="#FFFFFF" backcolor="#1F497D" uuid="5ea61540-2297-4aac-b06a-1c1dbaaf5286"/>
