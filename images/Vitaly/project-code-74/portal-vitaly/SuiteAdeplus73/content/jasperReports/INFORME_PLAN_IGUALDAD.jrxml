			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="150" y="560" width="170" height="160" forecolor="#1F497D" uuid="c95b5743-2cbd-43f1-b392-f657cb6f309f"/>
				<box leftPadding="10" rightPadding="10">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
