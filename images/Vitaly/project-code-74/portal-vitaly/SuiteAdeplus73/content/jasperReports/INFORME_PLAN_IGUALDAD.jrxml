					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[- Retribución anual media de las mujeres y de los hombres, desglosado por cada uno de los componentes salariales, así como por categoría profesional, por colectivo y por tipo de jornada (para comprobar que no se discrimina el personal a tiempo parcial se puede analizar la retribución/hora). ]]></text>
			</staticText>
			<staticText>
