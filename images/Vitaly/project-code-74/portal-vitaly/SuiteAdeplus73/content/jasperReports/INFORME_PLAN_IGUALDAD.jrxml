				</textElement>
				<textFieldExpression><![CDATA["Comportamientos Físicos:"]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" mode="Transparent" x="39" y="180" width="486" height="30" forecolor="#1F497D" uuid="000198bb-1962-47d2-b303-6bf14b3fbbae">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
