					<font fontName="Corbel" size="10" isBold="false"/>
				</textElement>
				<text><![CDATA[¿Cómo se ha hecho?]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="30" y="460" width="120" height="100" forecolor="#1F497D" uuid="9cb62e56-9fcf-46b0-ba58-44fdef23d3e4"/>
