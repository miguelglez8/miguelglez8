								<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
								<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
							</box>
							<textField textAdjust="StretchHeight">
								<reportElement positionType="Float" stretchType="RelativeToBandHeight" mode="Opaque" x="0" y="0" width="120" height="40" isRemoveLineWhenBlank="true" forecolor="#FFFFFF" backcolor="#1F497D" uuid="bf5ea49f-30f7-4121-806e-fa82f706dc31">
									<printWhenExpression><![CDATA[$F{noMedida}==false]]></printWhenExpression>
