			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="410" width="477" height="20" forecolor="#1F497D" uuid="1c6d2ee2-e300-453c-a5f5-28b171c65892">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[c) Cronograma]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="430" width="475" height="50" forecolor="#1F497D" uuid="e8510754-ba45-45a8-863a-c3366ac5c20e">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[1.  Las acciones recogidas en este Plan de Acción se implantarán a partir de la aprobación del Plan de Igualdad, y en todo caso, durante su primer año de vigencia o según lo establecido en el apartado VIII. CALENDARIO DE ACTUACIONES.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="480" width="475" height="30" forecolor="#1F497D" uuid="485f6dd6-2440-4b7d-bfa0-c4912af4fa25">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[2. Se realizará un seguimiento anual de las acciones. ]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="520" width="477" height="20" forecolor="#1F497D" uuid="f424727a-fc5d-4dfd-b1fb-be2337282583">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[d) Sistema de seguimiento e implementación]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="31" y="540" width="484" height="20" forecolor="#1F497D" uuid="0819b1a2-f0df-4c41-9528-d234ca9bf2f1">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[El seguimiento se llevará a cabo con las siguientes finalidades:]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="560" width="475" height="40" forecolor="#1F497D" uuid="04a779d5-a7bd-4e06-a960-4300c9ca05be">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[1. Velar  para que no existan diferencias en la retribución entre hombres y mujeres del mismo nivel o funciones, a través de la elaboración anual del registro salarial de retribuciones efectivas.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="600" width="475" height="40" forecolor="#1F497D" uuid="a454faf4-cf6c-4838-ab86-46ac8d05593e">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
