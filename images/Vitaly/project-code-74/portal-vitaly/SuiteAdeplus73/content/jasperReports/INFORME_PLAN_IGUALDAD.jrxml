				</textElement>
				<text><![CDATA[- Incremento salarial medio de las mujeres e incremento salarial medio de los hombres.  ]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="160" width="477" height="20" forecolor="#1F497D" uuid="50f28205-ea74-42b2-a905-4856767d4370">
