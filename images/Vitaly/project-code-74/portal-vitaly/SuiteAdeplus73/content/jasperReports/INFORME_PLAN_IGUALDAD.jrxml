		<band height="722">
			<property name="com.jaspersoft.studio.unit.height" value="px"/>
			<staticText>
				<reportElement x="30" y="10" width="446" height="20" forecolor="#EE9531" uuid="1bea1c58-a6d7-44f1-81d5-2cc4bd09e5c5">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[I. PARTES SUSCRIPTORAS DEL PLAN DE IGUALDAD.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="30" y="30" width="500" height="30" forecolor="#1F497D" uuid="d683d110-f3ff-48b9-a52e-375a8c750fd0">
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" verticalAlignment="Middle">
					<font fontName="Corbel" size="11" isBold="false" isUnderline="false"/>
				</textElement>
				<text><![CDATA[Se indican a continuación las partes legitimas que suscriben el Plan de Igualdad:]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="30" y="110" width="144" height="19" forecolor="#1F497D" uuid="fc14ce3e-71ff-4c37-9aab-1f8fd45c6a8c"/>
				<textElement>
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[2. Parte Empresarial:]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="30" y="60" width="144" height="19" forecolor="#1F497D" uuid="ea3ba192-af53-4c2e-abdf-caf772bdcbc0">
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Corbel" size="11" isBold="true" pdfEncoding=""/>
				</textElement>
				<text><![CDATA[1. Parte social:]]></text>
			</staticText>
			<componentElement>
				<reportElement positionType="Float" isPrintRepeatedValues="false" x="39" y="129" width="490" height="21" uuid="a12d2cc0-ceee-4d04-8661-48eb3c1b00a8"/>
				<jr:list xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" printOrder="Vertical">
					<datasetRun subDataset="informacionPreliminar" uuid="5b4e4bc7-4209-4951-90f7-8a1a6a73e86f">
						<dataSourceExpression><![CDATA[$P{repComNegRepreOrgBean}]]></dataSourceExpression>
					</datasetRun>
					<jr:listContents height="21" width="490">
						<textField textAdjust="StretchHeight">
							<reportElement x="0" y="0" width="490" height="20" forecolor="#1F497D" uuid="fa327561-0a57-4cc5-bb33-b3ff93757244"/>
							<textElement verticalAlignment="Middle">
								<font fontName="Corbel" size="11" isBold="false"/>
							</textElement>
							<textFieldExpression><![CDATA["· " + $F{puestoTrabajo}  + " - " + $F{nombreCompleto}]]></textFieldExpression>
						</textField>
					</jr:listContents>
				</jr:list>
			</componentElement>
			<componentElement>
				<reportElement positionType="Float" isPrintRepeatedValues="false" x="40" y="79" width="490" height="21" uuid="2a85c004-0177-460e-b864-43ebc46d83f5"/>
				<jr:list xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" printOrder="Vertical">
					<datasetRun subDataset="informacionPreliminar" uuid="df9fa7c0-ff29-4f0c-b43b-07fdea9ac839">
						<dataSourceExpression><![CDATA[$P{repComNegRepreSocBean}]]></dataSourceExpression>
					</datasetRun>
					<jr:listContents height="21" width="490">
						<textField textAdjust="StretchHeight">
							<reportElement x="0" y="0" width="490" height="20" forecolor="#1F497D" uuid="2ff789fe-bf41-457d-bf8d-5b2fb344a20e"/>
							<textElement verticalAlignment="Middle">
								<font fontName="Corbel" size="11" isBold="false"/>
							</textElement>
							<textFieldExpression><![CDATA["· " + $F{puestoTrabajo}  + " - " + $F{nombreCompleto}]]></textFieldExpression>
						</textField>
					</jr:listContents>
				</jr:list>
			</componentElement>
			<returnValue toVariable="INDEX_PARTES_SUSCRIPTORAS">
				<expression><![CDATA[$V{PAGE_NUMBER}]]></expression>
			</returnValue>
		</band>
		<band height="722">
			<property name="com.jaspersoft.studio.unit.height" value="px"/>
			<staticText>
				<reportElement x="30" y="10" width="446" height="20" forecolor="#EE9531" uuid="6ffe3708-9349-4cbf-a5a8-0c8530423471">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[II. ÁMBITO PERSONAL, TERRITORIAL Y TEMPORAL.]]></text>
			</staticText>
			<textField>
				<reportElement positionType="Float" x="30" y="30" width="496" height="50" forecolor="#1F497D" uuid="2fe5df27-f2f5-4eda-a1e2-bc36a7be6c78"/>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<p>Este Plan de Igualdad será de aplicación a la totalidad de las personas trabajadoras de la Organización, así como en su caso, a las personas cedidas por empresas de trabajo temporal, durante los períodos de prestación de servicio en la entidad usuaria. </p> "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="80" width="496" height="40" forecolor="#1F497D" uuid="e35de37c-c812-4f8a-a1b2-1bd46303fd3f"/>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<p>El ámbito territorial del Plan es " +$P{ambitoTerritorial}+ ($P{comentarioAmbitoTerritorial}!=null ?" ("+$P{comentarioAmbitoTerritorial}+ ")" :"") +", y afecta a todos los centros de trabajo.</p> "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="210" width="496" height="60" forecolor="#1F497D" uuid="d35646a7-3998-41ec-ba37-9d4d12485d41"/>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<p>Con el fin de posibilitar la firma de un nuevo Plan, la representación social y empresarial constituirán una comisión negociadora provisional tres meses antes de la finalización de su vigencia para comenzar las negociaciones del siguiente (RD 901/2020 de 13 de octubre).</p> "]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="30" y="126" width="496" height="74" forecolor="#1F497D" uuid="b0a4d270-42b8-472e-aeb1-522a3dc3fadb"/>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<p>Este Plan entra en vigor el día de su aprobación por la Comisión Negociadora de Igualdad, el "+ $P{fechaAprobacionPI}+ ", iniciándose a partir de la fecha indicada el plazo de 15 días para su remisión a la autoridad laboral competente, a los efectos de registro y depósito y publicidad en los términos previstos en el RD 901/2020 de 13 de octubre. Desde su vigencia el Plan de Igualdad estará en vigor durante "+ $P{nAnyosPeriodoPlan}+"</p> "]]></textFieldExpression>
			</textField>
			<returnValue toVariable="INDEX_AMBITO_PERSONAL">
				<expression><![CDATA[$V{PAGE_NUMBER}]]></expression>
			</returnValue>
		</band>
		<band height="700">
			<property name="com.jaspersoft.studio.unit.height" value="px"/>
			<staticText>
				<reportElement x="30" y="10" width="496" height="50" forecolor="#EE9531" uuid="30f46de0-658a-4483-804a-104b0c4663e3">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[III. RESULTADOS DEL INFORME DIAGNÓSTICO Y DE LA AUDITORÍA RETRIBUTIVA, Y PLAN DE ACCIÓN Y DE CORRECCIONES DE LAS DESIGUALDADES RETRIBUTIVAS]]></text>
			</staticText>
			<textField>
				<reportElement positionType="Float" x="30" y="70" width="496" height="40" forecolor="#1F497D" uuid="0da97de8-e380-4fbb-a479-ced353ea7ade"/>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<p>Conjuntamente con el Plan de Igualdad, se registra el Informe de Diagnóstico completo, así como la Auditoría Retributiva. Su contenido, se resume a continuación. </p> "]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="30" y="110" width="496" height="20" forecolor="#EE9531" uuid="40fdccb0-1287-4cd9-b551-999cc931a3a0">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="12" isBold="true" isUnderline="true"/>
				</textElement>
				<text><![CDATA[RESULTADOS DEL INFORME DIAGNÓSTICO]]></text>
			</staticText>
			<textField>
				<reportElement positionType="Float" x="30" y="130" width="496" height="30" forecolor="#1F497D" uuid="aa6b180a-11b4-41fc-87e9-d534fdb23afd"/>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<p>Se ha realizado un Informe Diagnóstico de la situación de Igualdad en "+$P{razonSocial}+" en el que, entre otros aspectos, se hacen constar los siguientes: </p> "]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="160" width="500" height="20" forecolor="#1F497D" uuid="2fb41aeb-1ac6-4df9-a9c8-4270a6d32666">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[· Metodología y herramientas utilizadas]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="180" width="500" height="20" forecolor="#1F497D" uuid="10ace6b4-5f59-4bcd-8360-917510ae604b">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[· Datos básicos de la Organización]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="200" width="500" height="20" forecolor="#1F497D" uuid="049352f4-c9f2-47c1-84be-c9ddeceb573a">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[· Información corporativa]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="220" width="500" height="20" forecolor="#1F497D" uuid="467a5c93-0fb0-44d7-b376-a1ee7d441e73">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[· Análisis cuantitativo de la plantilla]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="240" width="500" height="20" forecolor="#1F497D" uuid="c712912a-cb49-48e9-8adf-e8ad70876283">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[· Análisis de Igualdad por materias]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="270" width="500" height="20" forecolor="#1F497D" uuid="59d3be03-5df6-4d2a-ac14-5f578d98e86b">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[A continuación, se resumen las materias analizadas y las principales conclusiones:]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="40" y="300" width="490" height="20" forecolor="#1F497D" uuid="84ab3f84-7a15-4d3a-8f56-4ce5f09f9543">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<box leftPadding="5" rightPadding="5">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true" isUnderline="true"/>
				</textElement>
				<text><![CDATA[-  Materias analizadas en el Diagnóstico]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" mode="Transparent" x="30" y="320" width="500" height="30" forecolor="#1F497D" uuid="4adb6c1b-503d-41fd-be46-e52a79230f8d">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
