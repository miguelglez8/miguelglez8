					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta411_3} != null && $P{respuesta411_3}.equals("3") ? "&#9746; Jornada coincidente con el horario escolar" : "&#9744; Jornada coincidente con el horario escolar"]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="40" y="60" width="486" height="20" forecolor="#1F497D" uuid="d86bc6b3-b9ea-47ae-93c0-d4f5bb9d49d0">
