				<textFieldExpression><![CDATA["45.2. Si respondió afirmativamente a la pregunta 45, ¿el procedimiento dispone del protocolo de actuación frente al acoso para dar cauce a las quejas o denuncias que pudieran producirse, así como medidas cautelares y/o medidas correctivas aplicables?"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="540" width="496" height="50" forecolor="#1F497D" uuid="dd7e3e3d-bf45-4636-92a2-13ff7f0e9de6">
