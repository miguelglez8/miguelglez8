				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["45.1. Si respondió afirmativamente a la pregunta 45, ¿el procedimiento dispone de una declaración de principios, de la definición de acoso sexual y por razón de sexo, e identifica las conductas que pudieran ser constitutivas de acoso?"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="480" width="496" height="30" forecolor="#1F497D" uuid="17bf6263-18c7-4513-aa89-fa57406391dc">
