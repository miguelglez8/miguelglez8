				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[II. CUESTIONARIO]]></text>
			</staticText>
			<textField>
				<reportElement x="30" y="40" width="496" height="20" forecolor="#1F497D" uuid="259c7bac-6f21-4494-ad45-c1705cd01262">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["1. Describa brevemente la trayectoria de su Organización."]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight" isBlankWhenNull="true">
				<reportElement positionType="Float" x="30" y="60" width="496" height="20" forecolor="#1F497D" uuid="6ea93fb9-bd52-454f-ad9a-ebec26814688">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta10}]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight" isBlankWhenNull="true">
				<reportElement positionType="Float" x="30" y="120" width="496" height="20" forecolor="#1F497D" uuid="c8ffc887-d360-4a5f-b888-f6f97ec8283b">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta20}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="90" width="496" height="30" forecolor="#1F497D" uuid="2e56012d-70a2-4559-80c3-e325b025f083">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["2. Indique, en su caso, peculiaridades de la actividad desarrollada y de cada centro de trabajo."]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="150" width="496" height="20" forecolor="#1F497D" uuid="5b3f4fd3-66cc-40b1-91bd-4f6e95754ee2">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["3. Indique si su Organización dispone de un Canal ético o canal de denuncias . <sup>1</sup>"]]></textFieldExpression>
