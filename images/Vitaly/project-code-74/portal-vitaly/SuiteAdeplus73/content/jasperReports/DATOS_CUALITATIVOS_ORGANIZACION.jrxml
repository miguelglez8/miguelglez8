					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta411_1} != null && $P{respuesta411_1}.equals("1") ? "&#9746; Subvenciones económicas para guardería o ayuda escolar" : "&#9744; Subvenciones económicas para guardería o ayuda escolar"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="10" width="496" height="30" forecolor="#1F497D" uuid="8398ce15-07aa-43e3-82d9-53f2737f4309">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["41.1. Si respondió afirmativamente la pregunta 41, indique las medidas implantadas."]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="40" y="80" width="486" height="20" forecolor="#1F497D" uuid="4ee55efa-5fa8-424e-9dcb-b7ee5fa889f3">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Left" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta411_2} != null && $P{respuesta411_2}.equals("2") ? "&#9746; Flexibilidad de horarios en la entrada, la salida o durante el tiempo de la comida" : "&#9744; Flexibilidad de horarios en la entrada, la salida o durante el tiempo de la comida"]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="40" y="160" width="486" height="20" forecolor="#1F497D" uuid="17edc73a-f7b1-43e4-a2e8-0788fa84f76f">
