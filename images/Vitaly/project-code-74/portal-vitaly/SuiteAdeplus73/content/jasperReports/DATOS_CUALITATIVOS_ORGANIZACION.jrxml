				<textFieldExpression><![CDATA["<style isBold='true'>RAZÓN SOCIAL: </style>" + $P{razonSocial}]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="20" y="560" width="507" height="30" forecolor="#0B5394" uuid="2bc4cf42-e2eb-4fd7-803e-b0bc397f8890"/>
