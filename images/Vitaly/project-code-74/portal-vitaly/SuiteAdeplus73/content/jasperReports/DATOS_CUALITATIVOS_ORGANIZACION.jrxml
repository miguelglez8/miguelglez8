				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[VII. EJERCICIO CORRESPONSABLE DE LOS DERECHOS DE LA VIDA PERSONAL, FAMILIAR Y LABORAL]]></text>
			</staticText>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="160" y="570" width="130" height="20" forecolor="#1F497D" uuid="f17cd339-958c-43ad-b5f2-1bde5516e804">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta410} != null &&  $P{respuesta410}.equals("1") ? "&#9746; No" : "&#9744; No"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="530" width="496" height="40" forecolor="#1F497D" uuid="407b63e1-c22e-4906-9882-c1d2a1cf93c4">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["41. ¿La Organización tiene implantadas medidas para facilitar la conciliación personal, familiar y laboral y promover el ejercicio corresponsable de dichos derechos?"]]></textFieldExpression>
			</textField>
		</band>
		<band height="722">
			<property name="com.jaspersoft.studio.unit.height" value="px"/>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="40" y="40" width="486" height="20" forecolor="#1F497D" uuid="86459675-ccec-445a-bebb-9898a2dc4dc2">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Left" verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{respuesta411_0} != null && $P{respuesta411_0}.equals("0") ? "&#9746; Guardería en la Organización" : "&#9744; Guardería en la Organización"]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement positionType="Float" x="40" y="100" width="486" height="20" forecolor="#1F497D" uuid="0fc0b0f0-8635-49a9-86f7-9ba9a9e2188c">
