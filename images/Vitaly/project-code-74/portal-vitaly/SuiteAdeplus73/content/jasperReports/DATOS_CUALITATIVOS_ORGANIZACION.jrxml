				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["48. ¿Se amplían los derechos laborales y/o las medidas legalmente establecidas para las víctimas de violencia de género?"]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
