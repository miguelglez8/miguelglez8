				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["47. ¿Se prevé asesoramiento o apoyo profesional psicológico y/o médico a las víctimas de violencia de género?"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement positionType="Float" x="30" y="510" width="496" height="30" forecolor="#1F497D" uuid="755143b9-9f99-4d1e-9482-f4a643b08d9b">
