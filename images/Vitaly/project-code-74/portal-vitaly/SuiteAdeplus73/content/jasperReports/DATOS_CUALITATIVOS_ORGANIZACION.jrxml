				</textElement>
				<textFieldExpression><![CDATA[($P{respuesta411_6} != null && $P{respuesta411_6}.equals("6") ? "&#9746; Otras (especifique cuáles):" : "&#9744; Otras (especifique cuáles):") + ($P{respuesta411_other} !=null && !$P{respuesta411_other}.equals("") ? $P{respuesta411_other} : "....................")]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
