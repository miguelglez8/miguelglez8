				</reportElement>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["45. ¿Dispone de un procedimiento para la sensibilización, prevención, detección y actuación contra el acoso sexual y/o por razón de sexo?"]]></textFieldExpression>
			</textField>
		</band>
