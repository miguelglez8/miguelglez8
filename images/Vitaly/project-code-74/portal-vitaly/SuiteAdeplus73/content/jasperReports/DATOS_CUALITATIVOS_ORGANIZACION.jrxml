					<font fontName="Corbel" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[X. VÍCTIMAS DE VIOLENCIA DE GÉNERO Y PERSONAS EN SITUACIÓN DE RIESGO O EXCLUSIÓN SOCIAL]]></text>
			</staticText>
			<textField>
				<reportElement positionType="Float" x="30" y="570" width="496" height="30" forecolor="#1F497D" uuid="07a50bdb-02df-4d0e-ae31-5f6e16323265">
