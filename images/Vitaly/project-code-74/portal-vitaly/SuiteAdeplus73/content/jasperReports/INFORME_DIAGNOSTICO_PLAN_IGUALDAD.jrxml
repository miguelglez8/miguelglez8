					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Middle">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[Como introducción al análisis específico de la organización, interesa tener en cuenta el grado de masculinización/feminización en esta rama de actividad. Se presenta un gráfico con valores absolutos y porcentajes con respecto al total de cada sexo ]]></text>
			</staticText>
			<textField textAdjust="StretchHeight">
				<reportElement x="30" y="30" width="500" height="51" forecolor="#1F497D" uuid="a3bc4352-c0bc-4069-928e-edcfa4ca0488"/>
				<textElement textAlignment="Justified">
					<font fontName="Corbel" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["A continuación, se resumen las principales conclusiones obtenidas a partir del análisis de datos cuantitativos de las trabajadoras y trabajadores que permiten hacer una descripción de la situación actual desagregada por sexo de la empresa e identificación de los siguientes aspectos:"]]></textFieldExpression>
			</textField>
			<componentElement>
