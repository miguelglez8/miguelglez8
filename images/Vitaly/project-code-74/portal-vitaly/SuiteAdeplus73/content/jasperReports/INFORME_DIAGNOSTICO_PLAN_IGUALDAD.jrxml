				</textElement>
				<text><![CDATA[III. ANÁLISIS CUANTITATIVO DE LA PLANTILLA]]></text>
			</staticText>
			<staticText>
				<reportElement x="30" y="81" width="501" height="21" forecolor="#EE9531" uuid="3bba64e3-e145-4c7c-aa7d-8e077e5954f7">
