				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="styled">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[Los gráficos mostrados permiten valorar cómo influyen los estereotipos de género al asignar funciones ( <style isBold="true">segregación horizontal</style>) o cómo se reparten los puestos de responsabilidad entre mujeres y hombres en la Organización ( <style isBold="true">segregación vertical</style>)]]></text>
			</staticText>
