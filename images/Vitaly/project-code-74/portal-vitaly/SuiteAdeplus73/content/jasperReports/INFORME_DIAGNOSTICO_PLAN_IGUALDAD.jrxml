				<text><![CDATA[Formalizado el compromiso de la Organización]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="164" y="40" width="210" height="80" forecolor="#1F497D" uuid="7f60c943-e911-422c-9791-00ce909ce0b1"/>
				<box leftPadding="10" rightPadding="10">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
