				<textElement textAlignment="Left" markup="styled">
					<font fontName="Corbel" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[<style isBold="true">O. METODOLOGÍA</style>

<style isBold="true">I. INFORMACIÓN BÁSICA DE LA ORGANIZACIÓN</style>	

<style isBold="true">II. INFORMACIÓN CORPORATIVA</style>

<style isBold="true">III. ANÁLISIS CUANTITATIVO DE LA PLANTILLA</style>

