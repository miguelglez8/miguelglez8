					<font fontName="Corbel" size="10" isBold="false"/>
				</textElement>
				<text><![CDATA[Convocatoria de la Comisión Negociadora en relación al Informe Diagnóstico]]></text>
			</staticText>
			<textField>
				<reportElement x="30" y="530" width="500" height="90" forecolor="#1F497D" uuid="cf1d5093-0849-41c5-9594-ee71d50ae6c6"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="styled">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["En relación a lo expuesto, la dirección de la Organización ha facilitado a través de herramientas basadas en los formatos puestos a disposición de las Organizaciones por el Ministerio de Igualdad a través de <style isUnderline='true'>www.igualdadenlaempresa.es</style> todos los datos e información requerida para realizar el Diagnóstico, correspondientes al período  <style isBold='true'>" + $P{inicioPeriodoEstudio} +"</style> a <style isBold='true'>" + $P{finPeriodoEstudio} + "</style> empleando para ello medios eminentemente digitales: videoconferencias, portal on-line, correo electrónico, entre otros."]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="30" y="620" width="500" height="50" forecolor="#1F497D" uuid="67facd1f-0c67-4969-b12a-62f26d64a6c3"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="styled">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["El análisis de la información recibida ha sido encomendado a Adeplus Consultores para la elaboración del presente informe, para su posterior revisión, negociación  y eventual aprobación por la Comisión Negociadora integrada por: "]]></textFieldExpression>
			</textField>
		</band>
