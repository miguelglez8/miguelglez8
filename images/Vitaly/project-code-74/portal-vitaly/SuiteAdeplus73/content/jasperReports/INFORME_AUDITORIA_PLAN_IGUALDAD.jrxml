				<text><![CDATA[· Agrupaciones de puestos de trabajo de valor equivalente trabajos de valor equivalente.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="30" y="220" width="740" height="30" forecolor="#1F497D" uuid="e6b42789-e233-41d0-b749-0ad091d18fae">
