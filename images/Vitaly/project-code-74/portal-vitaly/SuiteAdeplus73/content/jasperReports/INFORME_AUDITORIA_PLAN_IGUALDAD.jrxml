				<textElement verticalAlignment="Top">
					<font fontName="Corbel" size="11" isBold="true" isItalic="true"/>
				</textElement>
				<text><![CDATA[c. Otros datos aportados por la Organización]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="30" y="30" width="740" height="40" forecolor="#1F497D" uuid="5bf5c2d6-ccde-4af7-9649-f47849354f90">
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="styled">
					<font fontName="Corbel" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[Si bien se hace un análisis muy exhaustivo de todas las políticas de personal en la elaboración del Diagnóstico previo al Plan de igualdad, para este informe interesa destacar particularmente la información aportada en materia de promociones por su impacto directo en el sistema retributivo de la Organización. ]]></text>
